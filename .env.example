# PostgreSQL — Neon (Vercel Marketplace)
# DATABASE_URL: string "Pooled connection" do painel (com -pooler no host)
# DIRECT_URL:   string "Direct connection" (sem pooler) — usada pelo migrate
# Para Postgres local (docker compose), use a mesma URL nos dois.
DATABASE_URL=postgresql://user:senha@ep-xxx-pooler.sa-east-1.aws.neon.tech/auditor_ai?sslmode=require&pgbouncer=true
DIRECT_URL=postgresql://user:senha@ep-xxx.sa-east-1.aws.neon.tech/auditor_ai?sslmode=require

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# Evolution API (WhatsApp)
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=change-me
EVOLUTION_INSTANCE=auditor
EVOLUTION_WEBHOOK_TOKEN=change-me-min-16-chars

# Hermes
PORT=3333

# Gate de senha do apps/web (uso pessoal, sem sistema de contas)
# AUTH_SECRET: string aleatória — `openssl rand -base64 32` ou equivalente
AUTH_SECRET=change-me
AUTH_PASSWORD=change-me
